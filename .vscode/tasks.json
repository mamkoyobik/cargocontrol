{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve site (PHP 127.0.0.1:8080)",
      "type": "shell",
      "command": "php",
      "args": [
        "-S",
        "127.0.0.1:8080",
        "-t",
        "${workspaceFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}
